# Generated logs
data/logs/*.log
data/logs/*.err.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.env

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Persistent runtime config (per-deployment, contains API key)
data/.config/
data/.sessions/

# User project volume — populated at container first-run from /app/template.
# The repo's authoritative templates live at the repo root; this directory
# is just where docker compose puts a user's working copy.
/project/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/

# Claude Code local settings (machine-specific)
.claude/settings.local.json

# OS temp
Thumbs.db

# Backup files
*.bak
*.orig
*.tmp
